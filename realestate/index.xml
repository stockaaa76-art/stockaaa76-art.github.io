<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>不動産投資 on 株価アート - Stock Analysis Dashboard</title><link>https://stock-kabu3.com/realestate/</link><description>Recent content in 不動産投資 on 株価アート - Stock Analysis Dashboard</description><generator>Hugo</generator><language>ja</language><atom:link href="https://stock-kabu3.com/realestate/index.xml" rel="self" type="application/rss+xml"/><item><title>不動産投資シミュレーター</title><link>https://stock-kabu3.com/realestate/simulator/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://stock-kabu3.com/realestate/simulator/</guid><description>&lt;div class="re-tool"&gt;
&lt;div class="re-section-label"&gt;物件情報&lt;/div&gt;
&lt;div class="re-grid"&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;物件価格（万円）&lt;/label&gt;
 &lt;input type="number" id="price" value="3000" min="1" step="100"&gt;
 &lt;/div&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;購入諸費用（万円）&lt;/label&gt;
 &lt;input type="number" id="cost" value="180" min="0" step="10"&gt;
 &lt;span class="re-hint"&gt;物件価格の5〜8%が目安&lt;/span&gt;
 &lt;/div&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;月額賃料想定（万円）&lt;/label&gt;
 &lt;input type="number" id="rent" value="12" min="0" step="0.5"&gt;
 &lt;/div&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;空室率想定（%）&lt;/label&gt;
 &lt;input type="number" id="vacancy" value="5" min="0" max="100" step="1"&gt;
 &lt;/div&gt;
&lt;/div&gt;
&lt;div class="re-section-label"&gt;運営コスト（月額）&lt;/div&gt;
&lt;div class="re-grid"&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;管理費・管理委託料（万円）&lt;/label&gt;
 &lt;input type="number" id="mgmt" value="0.6" min="0" step="0.1"&gt;
 &lt;span class="re-hint"&gt;賃料の5%が目安&lt;/span&gt;
 &lt;/div&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;修繕積立・その他（万円）&lt;/label&gt;
 &lt;input type="number" id="repair" value="0.5" min="0" step="0.1"&gt;
 &lt;/div&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;年間固定費（固定資産税等・万円）&lt;/label&gt;
 &lt;input type="number" id="fixedcost" value="10" min="0" step="1"&gt;
 &lt;/div&gt;
&lt;/div&gt;
&lt;div class="re-section-label"&gt;ローン条件&lt;/div&gt;
&lt;div class="re-grid"&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;頭金（万円）&lt;/label&gt;
 &lt;input type="number" id="downpayment" value="600" min="0" step="100"&gt;
 &lt;/div&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;金利（年利 %）&lt;/label&gt;
 &lt;input type="number" id="rate" value="2.0" min="0" max="20" step="0.1"&gt;
 &lt;/div&gt;
 &lt;div class="re-row"&gt;
 &lt;label&gt;返済期間（年）&lt;/label&gt;
 &lt;input type="number" id="loanterm" value="35" min="1" max="50" step="1"&gt;
 &lt;/div&gt;
&lt;/div&gt;
&lt;p&gt;&lt;button class="re-btn" onclick="calcRE()"&gt;計算する&lt;/button&gt;&lt;/p&gt;</description></item></channel></rss>