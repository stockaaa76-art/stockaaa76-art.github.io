<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>投資計算ツール on 株価アート - Stock Analysis Dashboard</title><link>https://stock-kabu3.com/tools/</link><description>Recent content in 投資計算ツール on 株価アート - Stock Analysis Dashboard</description><generator>Hugo</generator><language>ja</language><atom:link href="https://stock-kabu3.com/tools/index.xml" rel="self" type="application/rss+xml"/><item><title>ローン返済シミュレーター</title><link>https://stock-kabu3.com/tools/loan-simulator/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://stock-kabu3.com/tools/loan-simulator/</guid><description>&lt;div class="tool-container"&gt;
&lt;div class="tool-box"&gt;
 &lt;div class="tool-row"&gt;
 &lt;label&gt;借入金額（円）&lt;/label&gt;
 &lt;input type="number" id="principal" value="30000000" min="1" step="100000"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label&gt;年利（%）&lt;/label&gt;
 &lt;input type="number" id="rate" value="1.5" min="0" max="30" step="0.01"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label&gt;返済期間（年）&lt;/label&gt;
 &lt;input type="number" id="years" value="35" min="1" max="50" step="1"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label&gt;返済方式&lt;/label&gt;
 &lt;select id="method" style="flex:1; padding:8px 12px; font-size:15px; border:1px solid #d1d5db; border-radius:6px;"&gt;
 &lt;option value="equal-payment"&gt;元利均等返済（毎月同額）&lt;/option&gt;
 &lt;option value="equal-principal"&gt;元金均等返済（利息逓減）&lt;/option&gt;
 &lt;/select&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;button class="btn-primary" onclick="calculate()"&gt;計算する&lt;/button&gt;
 &lt;/div&gt;
&lt;/div&gt;
&lt;div id="result" class="result-box" style="display:none;"&gt;
 &lt;div class="result-grid"&gt;
 &lt;div class="result-card highlight"&gt;
 &lt;div class="result-label" id="monthly-label"&gt;月々の返済額&lt;/div&gt;
 &lt;div class="result-value" id="monthly-payment"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label"&gt;総支払額&lt;/div&gt;
 &lt;div class="result-value" id="total-payment"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label"&gt;総利息&lt;/div&gt;
 &lt;div class="result-value" id="total-interest"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label"&gt;元金に対する利息率&lt;/div&gt;
 &lt;div class="result-value" id="interest-ratio"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label"&gt;返済回数&lt;/div&gt;
 &lt;div class="result-value" id="payments"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label" id="first-label"&gt;初回返済額&lt;/div&gt;
 &lt;div class="result-value" id="first-payment"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-note" id="note"&gt;&lt;/div&gt;
 &lt;div id="schedule-wrap" style="margin-top:20px;"&gt;
 &lt;details&gt;
 &lt;summary style="cursor:pointer; font-size:14px; color:#3b82f6; font-weight:600;"&gt;年次返済スケジュールを表示&lt;/summary&gt;
 &lt;div style="overflow-x:auto; margin-top:10px;"&gt;
 &lt;table id="schedule-table" style="width:100%; border-collapse:collapse; font-size:13px;"&gt;
 &lt;thead&gt;
 &lt;tr style="background:#f3f4f6;"&gt;
 &lt;th style="padding:8px; text-align:right; border:1px solid #e5e7eb;"&gt;経過年&lt;/th&gt;
 &lt;th style="padding:8px; text-align:right; border:1px solid #e5e7eb;"&gt;年間返済額&lt;/th&gt;
 &lt;th style="padding:8px; text-align:right; border:1px solid #e5e7eb;"&gt;うち元金&lt;/th&gt;
 &lt;th style="padding:8px; text-align:right; border:1px solid #e5e7eb;"&gt;うち利息&lt;/th&gt;
 &lt;th style="padding:8px; text-align:right; border:1px solid #e5e7eb;"&gt;残元金&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody id="schedule-body"&gt;&lt;/tbody&gt;
 &lt;/table&gt;
 &lt;/div&gt;
 &lt;/details&gt;
 &lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
function fmt(n) { return Math.round(n).toLocaleString('ja-JP') + '円'; }
function fmtPct(n) { return n.toFixed(1) + '%'; }

function calculate() {
 const P = parseFloat(document.getElementById('principal').value) || 0;
 const annualRate = parseFloat(document.getElementById('rate').value) || 0;
 const years = parseInt(document.getElementById('years').value) || 1;
 const method = document.getElementById('method').value;
 const n = years * 12;
 const r = annualRate / 100 / 12;

 let monthlyPayment = 0, totalPayment = 0, totalInterest = 0, firstPayment = 0;
 const scheduleRows = [];

 if (method === 'equal-payment') {
 if (r === 0) {
 monthlyPayment = P / n;
 } else {
 monthlyPayment = P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
 }
 totalPayment = monthlyPayment * n;
 totalInterest = totalPayment - P;
 firstPayment = monthlyPayment;

 let balance = P;
 for (let y = 1; y &lt;= years; y++) {
 let yearPrincipal = 0, yearInterest = 0;
 for (let m = 0; m &lt; 12; m++) {
 const interest = balance * r;
 const principal = monthlyPayment - interest;
 yearInterest += interest;
 yearPrincipal += principal;
 balance -= principal;
 }
 scheduleRows.push({ year: y, payment: monthlyPayment * 12, principal: yearPrincipal, interest: yearInterest, balance: Math.max(0, balance) });
 }

 document.getElementById('monthly-label').textContent = '月々の返済額（一定）';
 document.getElementById('first-label').textContent = '初回返済額';
 } else {
 const monthlyPrincipal = P / n;
 firstPayment = monthlyPrincipal + P * r;
 totalPayment = 0;
 totalInterest = 0;

 let balance = P;
 for (let y = 1; y &lt;= years; y++) {
 let yearPayment = 0, yearPrincipal = 0, yearInterest = 0;
 for (let m = 0; m &lt; 12; m++) {
 const interest = balance * r;
 const payment = monthlyPrincipal + interest;
 yearPayment += payment;
 yearPrincipal += monthlyPrincipal;
 yearInterest += interest;
 balance -= monthlyPrincipal;
 totalPayment += payment;
 totalInterest += interest;
 }
 scheduleRows.push({ year: y, payment: yearPayment, principal: yearPrincipal, interest: yearInterest, balance: Math.max(0, balance) });
 }
 monthlyPayment = firstPayment;
 document.getElementById('monthly-label').textContent = '初回月返済額（以降逓減）';
 document.getElementById('first-label').textContent = '最終月返済額';
 const lastMonthPrincipal = monthlyPrincipal;
 const lastMonthInterest = lastMonthPrincipal * r;
 document.getElementById('first-payment').textContent = fmt(lastMonthPrincipal + lastMonthInterest);
 }

 document.getElementById('monthly-payment').textContent = fmt(monthlyPayment);
 document.getElementById('total-payment').textContent = fmt(totalPayment);
 document.getElementById('total-interest').textContent = fmt(totalInterest);
 document.getElementById('interest-ratio').textContent = fmtPct(totalInterest / P * 100);
 document.getElementById('payments').textContent = n.toLocaleString() + '回';
 if (method === 'equal-payment') {
 document.getElementById('first-payment').textContent = fmt(firstPayment);
 }

 document.getElementById('note').textContent =
 '借入 ' + P.toLocaleString('ja-JP') + ' 円 ／ 年利 ' + annualRate + '% ／ ' + years + ' 年返済';

 const tbody = document.getElementById('schedule-body');
 tbody.innerHTML = '';
 scheduleRows.forEach(row =&gt; {
 const tr = document.createElement('tr');
 tr.innerHTML = `
 &lt;td style="padding:6px 8px; text-align:right; border:1px solid #e5e7eb;"&gt;${row.year}年目&lt;/td&gt;
 &lt;td style="padding:6px 8px; text-align:right; border:1px solid #e5e7eb;"&gt;${Math.round(row.payment).toLocaleString()}円&lt;/td&gt;
 &lt;td style="padding:6px 8px; text-align:right; border:1px solid #e5e7eb;"&gt;${Math.round(row.principal).toLocaleString()}円&lt;/td&gt;
 &lt;td style="padding:6px 8px; text-align:right; border:1px solid #e5e7eb; color:#ef4444;"&gt;${Math.round(row.interest).toLocaleString()}円&lt;/td&gt;
 &lt;td style="padding:6px 8px; text-align:right; border:1px solid #e5e7eb;"&gt;${Math.round(row.balance).toLocaleString()}円&lt;/td&gt;
 `;
 tbody.appendChild(tr);
 });

 document.getElementById('result').style.display = 'block';
}
&lt;/script&gt;
&lt;style&gt;
