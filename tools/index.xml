 &lt;option value="JPY" selected&gt;JPY – 日本円&lt;/option&gt;
 &lt;option value="USD"&gt;USD – 米ドル&lt;/option&gt;
 &lt;option value="EUR"&gt;EUR – ユーロ&lt;/option&gt;
 &lt;option value="GBP"&gt;GBP – 英ポンド&lt;/option&gt;
 &lt;option value="CNY"&gt;CNY – 中国人民元&lt;/option&gt;
 &lt;option value="KRW"&gt;KRW – 韓国ウォン&lt;/option&gt;
 &lt;option value="AUD"&gt;AUD – 豪ドル&lt;/option&gt;
 &lt;option value="CHF"&gt;CHF – スイスフラン&lt;/option&gt;
 &lt;/select&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label&gt;変換先通貨&lt;/label&gt;
 &lt;select id="to-currency"&gt;
 &lt;option value="USD" selected&gt;USD – 米ドル&lt;/option&gt;
 &lt;option value="JPY"&gt;JPY – 日本円&lt;/option&gt;
 &lt;option value="EUR"&gt;EUR – ユーロ&lt;/option&gt;
 &lt;option value="GBP"&gt;GBP – 英ポンド&lt;/option&gt;
 &lt;option value="CNY"&gt;CNY – 中国人民元&lt;/option&gt;
 &lt;option value="KRW"&gt;KRW – 韓国ウォン&lt;/option&gt;
 &lt;option value="AUD"&gt;AUD – 豪ドル&lt;/option&gt;
 &lt;option value="CHF"&gt;CHF – スイスフラン&lt;/option&gt;
 &lt;/select&gt;
 &lt;/div&gt;
 &lt;details style="margin-top:4px;"&gt;
 &lt;summary style="cursor:pointer; font-size:13px; color:#6b7280;"&gt;レートを手動で入力する（自動取得が使えない場合）&lt;/summary&gt;
 &lt;div style="margin-top:12px; display:flex; flex-direction:column; gap:10px;" id="manual-rates"&gt;
 &lt;div class="tool-row"&gt;
 &lt;label style="width:120px;"&gt;USD/JPY&lt;/label&gt;
 &lt;input type="number" id="rate-USD" placeholder="例: 150.5" step="0.01" min="0"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label style="width:120px;"&gt;EUR/JPY&lt;/label&gt;
 &lt;input type="number" id="rate-EUR" placeholder="例: 163.0" step="0.01" min="0"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label style="width:120px;"&gt;GBP/JPY&lt;/label&gt;
 &lt;input type="number" id="rate-GBP" placeholder="例: 193.0" step="0.01" min="0"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label style="width:120px;"&gt;CNY/JPY&lt;/label&gt;
 &lt;input type="number" id="rate-CNY" placeholder="例: 20.7" step="0.01" min="0"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label style="width:120px;"&gt;KRW/JPY&lt;/label&gt;
 &lt;input type="number" id="rate-KRW" placeholder="例: 0.11" step="0.0001" min="0"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label style="width:120px;"&gt;AUD/JPY&lt;/label&gt;
 &lt;input type="number" id="rate-AUD" placeholder="例: 98.0" step="0.01" min="0"&gt;
 &lt;/div&gt;
 &lt;div class="tool-row"&gt;
 &lt;label style="width:120px;"&gt;CHF/JPY&lt;/label&gt;
 &lt;input type="number" id="rate-CHF" placeholder="例: 168.0" step="0.01" min="0"&gt;
 &lt;/div&gt;
 &lt;/div&gt;
 &lt;/details&gt;
 &lt;div class="tool-row"&gt;
 &lt;button class="btn-primary" onclick="convert()"&gt;換算する&lt;/button&gt;
 &lt;/div&gt;
&lt;/div&gt;
&lt;div id="result" class="result-box" style="display:none;"&gt;
 &lt;div class="convert-result"&gt;
 &lt;div class="convert-from" id="from-display"&gt;&lt;/div&gt;
 &lt;div class="convert-arrow"&gt;→&lt;/div&gt;
 &lt;div class="convert-to" id="to-display"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-grid" style="margin-top:16px;"&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label"&gt;適用レート&lt;/div&gt;
 &lt;div class="result-value" id="applied-rate" style="font-size:15px;"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label"&gt;逆レート&lt;/div&gt;
 &lt;div class="result-value" id="reverse-rate" style="font-size:15px;"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="result-card"&gt;
 &lt;div class="result-label"&gt;レート取得時刻&lt;/div&gt;
 &lt;div class="result-value" id="rate-time" style="font-size:13px;"&gt;&lt;/div&gt;
 &lt;/div&gt;
 &lt;/div&gt;
 &lt;div class="quick-table-wrap"&gt;
 &lt;div class="quick-table-title"&gt;クイック換算表&lt;/div&gt;
 &lt;div id="quick-table"&gt;&lt;/div&gt;
 &lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;script&gt;
let rates = {};
let rateTime = '';

const LABELS = {
 JPY: '日本円', USD: '米ドル', EUR: 'ユーロ', GBP: '英ポンド',
 CNY: '人民元', KRW: '韓国ウォン', AUD: '豪ドル', CHF: 'スイスフラン'
};
const SYMBOLS = {
 JPY: '¥', USD: '$', EUR: '€', GBP: '£',
 CNY: '¥', KRW: '₩', AUD: 'A$', CHF: 'Fr'
};

function fmtAmount(n, currency) {
 const decimals = ['JPY', 'KRW'].includes(currency) ? 0 : 2;
 return SYMBOLS[currency] + n.toLocaleString('ja-JP', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

async function fetchRates() {
 document.getElementById('rate-msg').textContent = 'レートを取得中...';
 try {
 const res = await fetch('https://open.er-api.com/v6/latest/JPY');
 if (!res.ok) throw new Error('fetch failed');
 const data = await res.json();
 rates = data.rates;
 rates['JPY'] = 1;
 const now = new Date();
 rateTime = now.toLocaleString('ja-JP', { timeZone: 'Asia/Tokyo' }) + ' JST（自動取得）';
 document.getElementById('rate-msg').textContent = '✓ レート取得済み（' + now.toLocaleTimeString('ja-JP') + ' JST）';
 document.getElementById('rate-msg').style.color = '#16a34a';
 } catch (e) {
 document.getElementById('rate-msg').textContent = '⚠ 自動取得失敗。手動でレートを入力してください。';
 document.getElementById('rate-msg').style.color = '#dc2626';
 }
}

function getRate(from, to) {
 const manualKeys = ['USD', 'EUR', 'GBP', 'CNY', 'KRW', 'AUD', 'CHF'];

 if (Object.keys(rates).length &gt; 0) {
 const fromJPY = rates[from];
 const toJPY = rates[to];
 if (fromJPY &amp;&amp; toJPY) return toJPY / fromJPY;
 }

 const manualRates = {};
 manualKeys.forEach(cur =&gt; {
 const el = document.getElementById('rate-' + cur);
 if (el &amp;&amp; parseFloat(el.value) &gt; 0) {
 manualRates[cur] = 1 / parseFloat(el.value);
 }
 });
 manualRates['JPY'] = 1;

 const fromJPY = manualRates[from];
 const toJPY = manualRates[to];
 if (fromJPY &amp;&amp; toJPY) {
 rateTime = '手動入力レート';
 return toJPY / fromJPY;
 }
 return null;
}

function convert() {
 const amount = parseFloat(document.getElementById('amount').value) || 0;
 const from = document.getElementById('from-currency').value;
 const to = document.getElementById('to-currency').value;

 const rate = getRate(from, to);
 if (!rate) {
 alert('レートが取得できていません。「最新レートを取得」を押すか、手動でレートを入力してください。');
 return;
 }

 const converted = amount * rate;
 document.getElementById('from-display').textContent = fmtAmount(amount, from) + ' ' + from;
 document.getElementById('to-display').textContent = fmtAmount(converted, to) + ' ' + to;
 document.getElementById('applied-rate').textContent = '1 ' + from + ' = ' + rate.toFixed(4) + ' ' + to;
 document.getElementById('reverse-rate').textContent = '1 ' + to + ' = ' + (1 / rate).toFixed(4) + ' ' + from;
 document.getElementById('rate-time').textContent = rateTime || '—';

 const multiples = [1, 5, 10, 50, 100, 500, 1000, 5000, 10000];
 const tableHTML = '&lt;table class="quick-table"&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;' + from + '&lt;/th&gt;&lt;th&gt;' + to + '&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;' +
 multiples.map(m =&gt; '&lt;tr&gt;&lt;td&gt;' + fmtAmount(m, from) + '&lt;/td&gt;&lt;td&gt;' + fmtAmount(m * rate, to) + '&lt;/td&gt;&lt;/tr&gt;').join('') +
 '&lt;/tbody&gt;&lt;/table&gt;';
 document.getElementById('quick-table').innerHTML = tableHTML;

 document.getElementById('result').style.display = 'block';
}

fetchRates();
&lt;/script&gt;
&lt;style&gt;
.tool-container { max-width: 580px; margin: 0 auto; }
